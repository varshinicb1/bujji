BUJJI_LLM__PROVIDER=ollama
BUJJI_LLM__MODEL=llama3.2
BUJJI_LLM__BASE_URL=http://localhost:11434

# For OpenAI-compatible APIs:
# BUJJI_LLM__PROVIDER=openai
# BUJJI_LLM__MODEL=gpt-4o
# BUJJI_LLM__API_KEY=sk-...

# For OpenRouter:
# BUJJI_LLM__PROVIDER=openrouter
# BUJJI_LLM__MODEL=anthropic/claude-sonnet
# BUJJI_LLM__API_KEY=sk-or-...

BUJJI_MEMORY__TYPE=sqlite
BUJJI_MEMORY__SQLITE_PATH=~/.bujji/memory.db

BUJJI_ROUTER__LOCAL_THRESHOLD=0.7

BUJJI_LOGING__LEVEL=INFO

GITHUB_TOKEN=
